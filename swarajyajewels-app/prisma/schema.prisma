generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String    @id @default(cuid())
  phone        String    @unique
  email        String?
  firstName    String?
  lastName     String?
  isVerified   Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  addresses    Address[]
  orders       Order[]
  otpRecords   OtpVerification[]
}

model Address {
  id          String       @id @default(cuid())
  userId      String
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        String       @default("HOME")
  flatHouse   String
  areaStreet  String
  city        String
  state       String
  pincode     String
  phone       String?
  isDefault   Boolean      @default(false)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@unique([userId, flatHouse, areaStreet, city, state, pincode])
  @@index([userId])
}

model Order {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id])
  firstName      String?
  lastName       String?
  email          String?
  items          Json
  totalAmount    Float
  status         String   @default("PENDING")
  paymentMethod  String?
  payuTxnId      String?  @unique
  payuStatus     String?
  payuResponse   Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([userId])
  @@index([status])
}

model OtpVerification {
  id        String   @id @default(cuid())
  phone     String
  code      String?
  sessionId String?
  expiresAt DateTime
  verified  Boolean  @default(false)
  userId    String?
  createdAt DateTime @default(now())

  user      User?    @relation(fields: [userId], references: [id])

  @@index([phone])
  @@index([userId])
}

model CheckoutSession {
  id        String   @id @default(cuid())
  phone     String
  deviceId  String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([phone, deviceId])
  @@index([expiresAt])
}
